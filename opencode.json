{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "rei",
  "instructions": ["AGENTS.md"],
  "permission": {
    "edit": "ask",
    "bash": {
      "*": "ask",
      "git *": "allow",
      "code-review-graph *": "allow",
      "git commit *": "deny",
      "git push *": "deny",
      "rm *": "deny"
    },
    "external_directory": "allow"
  },
  "compaction": { "auto": true, "tail_turns": 15 }
}
