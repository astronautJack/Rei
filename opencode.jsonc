{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["docs/avsession-access.md"],
  "references": {
    "media-playback-controller": {
      "repository": "https://gitcode.com/CBG_CR/huawei/hap/HMOS_base_OH/MediaPlaybackController.git",
      "description": "HMOS 媒体播放控制器 hap 源码（私有，需本机已配 gitcode 凭证）"
      // TODO: 此仓库用"开发分支"，填入字面分支名后取消下行注释
      // "branch": "<开发分支名>"
    },
    "scene-board-ext": {
      "repository": "https://gitcode.com/CBG_CR_HarmonyOS/hmf/windows/scene_board_ext.git",
      "description": "HarmonyOS 场景板扩展源码（私有，需本机已配 gitcode 凭证）"
      // TODO: 此仓库用"开发分支"，填入字面分支名后取消下行注释
      // "branch": "<开发分支名>"
    }
    // 备注：若团队对私有 gitcode 仓库统一用 SSH，把上面两个 repository
    // 换成 git@gitcode.com:CBG_CR/.../*.git 即可（凭证走本机 SSH key）。
    // AVSession 不在此处——它是内网服务器 SSH 访问，见 docs/avsession-access.md。
  },
  "default_agent": "dev",
  "permission": {
    "edit": "ask",
    "bash": { "*": "ask", "git *": "allow", "git commit *": "deny", "git push *": "deny", "rm *": "deny" },
    "external_directory": "allow"
  }
  // TODO(Phase1-Serena): 本地 LSP MCP。需先装 Serena：`uv tool install -p 3.13 serena-agent`（内网包源/镜像待确认）。
  // 装好后取消下行注释启用：
  // ,"mcp": { "serena": { "type": "local", "command": ["uvx","--from","serena-agent","serena","start-mcp-server","--context","ide-assistant"], "enabled": true } }
  // TODO(Phase1-DeepWiki): 接入方式待向隔壁组确认（MCP/API/本地导出），定后补 mcp 配置。
}
